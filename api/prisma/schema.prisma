// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------------------
// CORE ENTITIES - CINEMATIC STORYBOARDING (Axiom Multi-Tenant)
// -------------------------------------------------------------

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  
  projects  Project[]
  users     User[]

  @@map("organizations")
}

model User {
  id             String         @id @default(uuid())
  orgId          String
  email          String         @unique
  role           String         @default("viewer") // viewer, editor, admin, owner
  passwordHash   String?        // null for invited users until they set a password
  mfaEnabled     Boolean        @default(false)
  mfaSecret      String?        // TOTP secret (encrypted at rest in production)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refreshTokens  RefreshToken[]

  @@index([orgId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique   // SHA-256 of the raw token sent to the client
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Project {
  id           String       @id @default(uuid())
  orgId        String
  name         String
  aspectRatio  String       @default("2.39:1") // standard cinematic
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sequences    Sequence[]

  // Indexes for optimal paginated queries targeting specific tenants per AXIOM standard
  @@index([orgId, createdAt(sort: Desc)])
  @@map("projects")
}

model Sequence {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots       Shot[]

  @@index([projectId])
  @@map("sequences")
}

model Shot {
  id           String    @id @default(uuid())
  sequenceId   String
  name         String
  orderIndex   Int       @default(0)
  durationSec  Float     @default(5.0)
  sceneData    Json?     // Stores the Three.js R3F serialized graph (cameras, rigs, lights, etc)
  thumbnailUrl String?   // S3 presigned URL cache
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  sequence     Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("shots")
}

// -------------------------------------------------------------
// AUDIT LOG — append-only, no updatedAt, no deletedAt
// -------------------------------------------------------------

model AuditLog {
  id            String   @id @default(uuid())
  orgId         String
  actorId       String   // User who performed the action
  action        String   // e.g. "project.create", "user.delete"
  resourceType  String   // e.g. "Project", "Shot", "User"
  resourceId    String   // ID of the affected resource
  ip            String?  // Request IP (may be absent for internal actions)
  correlationId String?  // X-Correlation-ID for request tracing
  metadata      Json?    // Optional before/after snapshots or extra context
  createdAt     DateTime @default(now())

  @@index([orgId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}
