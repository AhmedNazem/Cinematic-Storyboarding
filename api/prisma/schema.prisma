// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------------------
// CORE ENTITIES - CINEMATIC STORYBOARDING (Axiom Multi-Tenant)
// -------------------------------------------------------------

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  projects  Project[]
  users     User[]

  @@map("organizations")
}

model User {
  id             String       @id @default(uuid())
  orgId          String
  email          String       @unique
  role           String       @default("viewer") // viewer, editor, admin, owner
  authProviderId String?      // For NextAuth/Auth0 linking
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("users")
}

model Project {
  id           String       @id @default(uuid())
  orgId        String
  name         String
  aspectRatio  String       @default("2.39:1") // standard cinematic
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sequences    Sequence[]

  // Indexes for optimal paginated queries targeting specific tenants per AXIOM standard
  @@index([orgId, createdAt(sort: Desc)])
  @@map("projects")
}

model Sequence {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots       Shot[]

  @@index([projectId])
  @@map("sequences")
}

model Shot {
  id          String   @id @default(uuid())
  sequenceId  String
  name        String
  orderIndex  Int      @default(0)
  durationSec Float    @default(5.0)
  sceneData   Json?    // Stores the Three.js R3F serialized graph (cameras, rigs, lights, etc)
  thumbnailUrl String? // S3 presigned URL cache
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("shots")
}
