# ========================
# MONOREPO .gitignore
# Covers: api/ (Express) + web/ (Next.js)
# ========================

# --- Dependencies ---
node_modules/

# --- Environment variables (NEVER commit secrets) ---
.env
.env.*
!.env.example

# --- Next.js (web/) ---
.next/
out/

# --- Build output ---
dist/
build/

# --- Prisma (api/) ---
api/prisma/migrations/

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Testing ---
coverage/

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS files ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/settings.json
.idea/

# --- Misc ---
*.pem
.vercel
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
